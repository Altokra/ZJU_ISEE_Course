                  colframe=black,% black frame colour
                  width=0.9\textwidth,% 之前是8cm，已修改为自适应宽度
                  arc=1mm, auto outer arc,
                  boxrule=0.5pt,
                 ]
{#1}
\end{tcolorbox}
\end{center}
}

